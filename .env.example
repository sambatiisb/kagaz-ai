# Azure OpenAI — https://portal.azure.com
# Resource → "Keys and Endpoint" tab
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-32-char-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# Azure Document Intelligence — https://portal.azure.com
# Resource → "Keys and Endpoint" tab
AZURE_DI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_DI_KEY=your-32-char-key-here

# Azure Speech Service — https://portal.azure.com
# Resource → "Keys and Endpoint" tab
# Region examples: eastus, centralindia, southeastasia
AZURE_SPEECH_KEY=your-32-char-key-here
AZURE_SPEECH_REGION=eastus
